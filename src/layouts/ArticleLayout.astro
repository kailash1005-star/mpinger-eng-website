---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import NewsCard from '../components/NewsCard.astro';

const { article, related = [] } = Astro.props;
const shareIcons = ['LinkedIn', 'X', 'Facebook', 'E-mail'];
---
<BaseLayout title={`${article.title} — DMG MORI`} description={article.intro}>
  <Breadcrumb items={article.breadcrumb} />

  <article class="article">
    <header class="article-hero">
      <div class="container article-hero__inner">
        <div class="article-meta">
          <span class="article-tag">{article.tag}</span>
          <time class="article-date">{article.date}</time>
          {article.readingTime && <span class="article-reading">{article.readingTime}</span>}
        </div>
        <h1 class="article-title">{article.title}</h1>
        <p class="article-intro">{article.intro}</p>
      </div>
    </header>

    {article.hero && (
      <figure class="article-hero-media container">
        <img src={article.hero} alt={article.title} />
        {article.heroCaption && <figcaption>{article.heroCaption}</figcaption>}
      </figure>
    )}

    <div class="container article-body">
      <div class="article-content">
        {article.body.map((block) => {
          if (block.type === 'heading') return <h2>{block.text}</h2>;
          if (block.type === 'text') return <p>{block.text}</p>;
          if (block.type === 'quote') return (
            <blockquote class="article-quote">
              <p>{block.text}</p>
              {block.cite && <cite>{block.cite}</cite>}
            </blockquote>
          );
          if (block.type === 'image') return (
            <figure class="article-figure ci-text-media">
              <img src={block.src} alt={block.caption || ''} loading="lazy" />
              {block.caption && <figcaption class="ci-text-media-caption">{block.caption}</figcaption>}
            </figure>
          );
          if (block.type === 'facts') return (
            <ul class="article-facts">
              {block.items.map((f) => <li><strong>{f.value}</strong><span>{f.label}</span></li>)}
            </ul>
          );
          return null;
        })}

        <!-- Social share -->
        <div class="ci-share-social-media">
          <span class="ci-share-social-media-title">Share</span>
          {shareIcons.map((s) => <button class="ci-share-social-media-button">{s}</button>)}
        </div>
      </div>
    </div>
  </article>

  {related.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <p class="eyebrow">More from the newsroom</p>
        <h2>Related stories</h2>
        <div class="related-grid">
          {related.map((r) => <NewsCard item={r} />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .article-hero { padding-block: var(--sp-7) var(--sp-4); }
  .article-hero__inner { max-width: 820px; }
  .article-meta { display: flex; align-items: center; gap: var(--sp-3); margin-bottom: var(--sp-4); }
  .article-tag { background: var(--c-accent); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; padding: 3px 10px; border-radius: var(--radius); }
  .article-date, .article-reading { color: var(--c-text-muted); font-size: var(--fs-small); }
  .article-title { font-size: clamp(28px, 4vw, 44px); margin-bottom: var(--sp-4); }
  .article-intro { font-size: 19px; line-height: 1.6; color: #333; }

  .article-hero-media { margin: var(--sp-5) auto var(--sp-6); }
  .article-hero-media img { width: 100%; border-radius: var(--radius); }
  .article-hero-media figcaption { color: var(--c-text-muted); font-size: var(--fs-small); margin-top: var(--sp-2); }

  .article-body { display: flex; justify-content: center; padding-bottom: var(--sp-8); }
  .article-content { max-width: 820px; width: 100%; font-size: 17px; line-height: 1.75; }
  .article-content h2 { margin-top: var(--sp-7); }
  .article-quote { border-left: 4px solid var(--c-primary); margin: var(--sp-6) 0; padding: var(--sp-2) 0 var(--sp-2) var(--sp-5); }
  .article-quote p { font-family: var(--font-heading); font-size: 24px; font-weight: 700; line-height: 1.3; margin-bottom: var(--sp-2); }
  .article-quote cite { color: var(--c-text-muted); font-style: normal; font-size: var(--fs-body); }
  .article-figure { margin: var(--sp-6) 0; }
  .article-figure img { width: 100%; border-radius: var(--radius); }
  .ci-text-media-caption { color: var(--c-text-muted); font-size: var(--fs-small); margin-top: var(--sp-2); }
  .article-facts { list-style: none; padding: 0; margin: var(--sp-6) 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-4); }
  .article-facts li { border-top: 3px solid var(--c-primary); padding-top: var(--sp-3); }
  .article-facts strong { display: block; font-family: var(--font-heading); font-size: 28px; color: var(--c-text); }
  .article-facts span { color: var(--c-text-muted); font-size: var(--fs-small); }

  .ci-share-social-media { display: flex; align-items: center; gap: var(--sp-3); margin-top: var(--sp-7); padding-top: var(--sp-5); border-top: 1px solid var(--c-border); flex-wrap: wrap; }
  .ci-share-social-media-title { font-family: var(--font-heading); font-weight: 700; text-transform: uppercase; font-size: var(--fs-small); }
  .ci-share-social-media-button { border: 1px solid var(--c-border); background: #fff; border-radius: var(--radius); padding: 6px 14px; font-size: var(--fs-small); cursor: pointer; }
  .ci-share-social-media-button:hover { border-color: var(--c-accent); color: var(--c-accent); }

  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-5); margin-top: var(--sp-5); }
  @media (max-width: 1023px) { .related-grid { grid-template-columns: 1fr; } .article-facts { grid-template-columns: 1fr; } }
</style>
